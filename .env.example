# ==========================================
# Configuración Segura de Base de Datos
# ==========================================
POSTGRES_USER=admin_notas
POSTGRES_PASSWORD=EligeUnaClaveSegura2026
POSTGRES_DB=notas_produccion

# IMPORTANTE: Esta URL servirá si corres la app nativamente (fuera de Docker) contra el Docker de Postgres.
# Sin embargo, dentro de Docker Compose se inyecta automáticamente el host '@db'.
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}